### OpenAI - gpt-5.5
curl -X POST "{{OPENAI_BASE_URL}}/chat/completions" \
  -H "Authorization: Bearer {{OPENAI_API_KEY}}" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "gpt-5.5",
    "messages": [
      {"role": "system", "content": "Esti un comedian roman."},
      {"role": "user", "content": "Un scenariu de film de 100 de cuvinte, amuzant, fara limbaj ofensator."}
    ]
  }'



